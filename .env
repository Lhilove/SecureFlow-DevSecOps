# =============================================================================
# SecureFlow — local .env  (loaded automatically by Docker Compose)
#
# INTENTIONALLY INSECURE lab baseline — this file IS vulnerability IV-04
# ("secrets committed to the repo"). Local / isolated use only.
# Never point this at a real AWS account: the infra module uses
# AdministratorAccess and publicly-accessible RDS on purpose.
#
# I could not read your docker-compose.yml directly, so the VARIABLE NAMES
# here are the conventional ones. Open docker-compose.yml and match each name
# to what it references as ${...} (or under each service's `environment:`),
# and rename below if yours differ. The 5 "secrets" IV-04 counts are the two
# AWS keys + the two DB passwords + the JWT secret.
# =============================================================================

# ---- AWS ---------------------------------------------------------------------
# Canonical AWS *example* placeholders from AWS's own docs — NOT live creds,
# but they trip every secret scanner (Gitleaks, etc.), which is the exercise.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7ABCDE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYWERHVILKEY
AWS_DEFAULT_REGION=us-east-1

# ---- auth-db  (PostgreSQL) ---------------------------------------------------
# These same values also feed the auth-db container's POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB via the compose file. In-network the service
# reaches it on port 5432 (host-mapped to 5432 in compose).
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=secureflow_auth
AUTH_DB_USER=secureflow
AUTH_DB_PASSWORD=authpassword

# ---- transaction-db  (PostgreSQL) --------------------------------------------
# In-network port is 5432 (host-mapped to 5433 in compose — use 5432 here).
TRANSACTION_DB_HOST=transaction-db
TRANSACTION_DB_PORT=5432
TRANSACTION_DB_NAME=secureflow_transactions
TRANSACTION_DB_USER=secureflow
TRANSACTION_DB_PASSWORD=txnpassword

# ---- JWT ---------------------------------------------------------------------
# Shared secret: auth-service signs the token, transaction-service verifies it.
# Deliberately weak to match the JWT weaknesses in the brief (AV-07 / none-alg).
JWT_SECRET=supersecretjwtkey

# ---- Flask -------------------------------------------------------------------
FLASK_ENV=development
